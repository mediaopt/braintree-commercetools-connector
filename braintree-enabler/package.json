{
  "name": "braintree-commercetools-client",
  "version": "0.01.29",
  "private": false,
  "type": "module",
  "license": "MIT",
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "braintree-web": "^3.138.0",
    "classnames": "^2.3.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "dev": "vite",
    "start": "npm run prebuild && vite --host 0.0.0.0",
    "build": "tsc && vite build",
    "test.coverage": "jest  --runInBand --no-cache --coverage",
    "clean": "rimraf dist",
    "copy-files": "copyfiles -e *.ts -e **/*.ts -e **/*.tsx -u 1 src/**/**/*.css dist/esm/src",
    "tsc-local": "npm run clean && tsc -p tsconfig.json && tsc -p tsconfig-cjs.json && npm run copy-files",
    "prepare-local": "npm run tsc",
    "tsc": "tsc -p tsconfig.json && tsc -p tsconfig-cjs.json && npm run copy-files",
    "prepare": "npm run tsc"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "@jest/types": "^30.3.0",
    "@types/braintree-web": "^3.75.23",
    "@types/uuid": "^9.0.1",
    "tailwindcss": "^3.3.2",
    "copyfiles": "^2.4.1",
    "vite": "^8.0.2",
    "@vitejs/plugin-react": "^6.0.1",
    "vite-plugin-css-injected-by-js": "3.5.2",
    "rimraf": "6.1.3",
    "ts-node": "^10.9.2"
  }
}
