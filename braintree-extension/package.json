{
  "name": "service-typescript",
  "description": "",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start": "node build/index.js",
    "gcp-build": "tsc",
    "start:dev": "concurrently -k \"tsc --watch\" \"nodemon -q build/index.js\"",
    "build": "npm --prefix ../common-connect install && npm --prefix ../common-connect run build && rimraf ./build && tsc",
    "lint": "eslint . --ext .ts",
    "prettier": "prettier --write '**/*.{js,ts}'",
    "test": "npm run build && jest --config jest.config.cjs",
    "test:watch": "npm run build && jest --watch",
    "connector:post-deploy": "node build/connector/post-deploy.js",
    "connector:pre-undeploy": "node build/connector/pre-undeploy.js"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@ngrok/ngrok": "1.7.0",
    "@tsconfig/recommended": "^1.0.2",
    "@types/braintree": "^3.3.7",
    "@types/express": "^4.17.14",
    "@types/jest": "^29.0.3",
    "@types/node": "^18.7.18",
    "@types/validator": "^13.7.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^7.4.0",
    "eslint": "10.0.3",
    "jest": "^30.2.0",
    "nodemon": "^3.0.1",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "ts-jest": "^29.0.5",
    "typescript": "^4.8.3"
  },
  "dependencies": {
    "@commercetools-backend/loggers": "27.4.2",
    "@commercetools/platform-sdk": "^4.0.0",
    "@commercetools/sdk-client-v2": "^2.0.0",
    "body-parser": "2.2.1",
    "braintree": "^3.13.0",
    "common-connect": "link:../common-connect",
    "dotenv": "^16.0.3",
    "express": "^4.21.1",
    "validator": "13.15.22"
  },
  "resolutions": {
    "lodash": "^4.18.1"
  }
}
